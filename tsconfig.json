{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "//": "include is scoped to source dirs — node_modules is a symlink, so a broad **/*.ts glob would type-check dependency files via the resolved path.",
  "include": [
    "next-env.d.ts",
    "*.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "content/**/*.ts",
    "scripts/**/*.ts",
    ".next.nosync/types/**/*.ts"
  ],
  "exclude": ["node_modules", "node_modules.nosync", ".next.nosync"]
}
